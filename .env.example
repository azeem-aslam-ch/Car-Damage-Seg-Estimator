# ─────────────────────────────────────────────
# Car Damage Segmentation Estimator – .env
# Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# Model weights path (inside container / relative to backend)
MODEL_WEIGHTS_PATH=data/weights/best.pt

# Fall-back to pretrained YOLOv8s-seg if custom weights not found
PRETRAINED_WEIGHTS=yolov8s-seg.pt

# Detection confidence threshold (0.0 – 1.0)
CONFIDENCE_THRESHOLD=0.25

# IoU threshold for NMS
IOU_THRESHOLD=0.45

# Output directories (mounted as Docker volumes)
OUTPUT_DIR=data/outputs
REPORTS_DIR=data/reports
WEIGHTS_DIR=data/weights

# Backend URL (used by Streamlit frontend)
BACKEND_URL=http://backend:8000

# CORS origins (comma-separated)
CORS_ORIGINS=*

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
